#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$HOME/.claude/skills"

SKILLS=("socratic" "learn" "produce")

echo "Installing Socratic skills..."

mkdir -p "$SKILLS_DIR"

for SKILL in "${SKILLS[@]}"; do
  TARGET="$SKILLS_DIR/$SKILL"
  SOURCE="$REPO_DIR/$SKILL"

  if [ ! -d "$SOURCE" ]; then
    echo "Warning: $SOURCE not found, skipping."
    continue
  fi

  if [ -L "$TARGET" ] || [ -d "$TARGET" ]; then
    rm -rf "$TARGET"
  fi

  ln -s "$SOURCE" "$TARGET"
  echo "Linked: $TARGET -> $SOURCE"
done

echo ""
echo "Done. /socratic, /learn, and /produce are now available in Claude Code."
